---
interface Props {
  title: string;
  authors: string;
  venue: string; // e.g., "CVPR, 2024"
  description: string;
  image: string;
  projectUrl?: string;
  pdfUrl?: string;
  arxivUrl?: string;
}

const { title, authors, venue, description, image, projectUrl, pdfUrl, arxivUrl } = Astro.json;
---

<div class="flex flex-col md:flex-row gap-6 mb-12 group">
  <div class="w-full md:w-1/3 aspect-[4/3] overflow-hidden rounded-lg bg-neutral-800 border border-neutral-700">
    <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
  </div>

  <div class="flex-1 flex flex-col justify-start">
    <h2 class="text-xl font-bold text-neutral-100 mb-1">{title}</h2>
    <p class="text-sm text-neutral-400 mb-1">{authors}</p>
    <p class="text-xs text-neutral-500 italic mb-3">{venue}</p>
    <p class="text-sm text-neutral-300 leading-relaxed mb-4">{description}</p>
    
    <div class="flex gap-4 text-xs text-neutral-400">
      {projectUrl && <a href={projectUrl} class="hover:text-white flex items-center gap-1">🌐 Project</a>}
      {pdfUrl && <a href={pdfUrl} class="hover:text-white flex items-center gap-1">📄 PDF</a>}
      {arxivUrl && <a href={arxivUrl} class="hover:text-white flex items-center gap-1">🔗 arXiv</a>}
    </div>
  </div>
</div>