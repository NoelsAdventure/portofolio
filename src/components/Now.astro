---
import Card from "./Card/index.astro";
import Pulse from "./Pulse.astro";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2">
  <div class="flex justify-between w-full items-start mb-2">
    <div class="flex items-baseline gap-2">
      <h2 class="m-0 text-xl font-bold">Now</h2>
      <a href="https://sive.rs/nowff" target="_blank" class="no-underline">
        <span class="text-xs text-gray-500 cursor-pointer hover:text-primary-500 transition-colors">what's that ?</span>
      </a>
    </div>
    <Pulse />
  </div>
  <p class="text-xs">Currently working fulltime</p>
</Card>