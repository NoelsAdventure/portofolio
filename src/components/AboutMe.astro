---
import Card from "./Card/index.astro";
import { Image } from "astro:assets";

// Import your images from your local assets folder
// You can add more from your Bokan-Kepulauan folder!
const photos = [
  { src: "/me.webp", alt: "Zion Mountains" },
  { src: "/me.png", alt: "Robotics Research" },
  { src: "/preview.png", alt: "Gunpla Build" },
];
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-6" title="About me">
  <div class="flex flex-col gap-4 h-full">
    <div class="flex flex-col gap-2">
      <div class="text-sm font-light">
        <p>
          Hi, I'm Noel, a PhD researcher at the University of Houston focused on perception-aware control for multi-UAV systems.
        </p>
      </div>
      <p class="text-sm font-light">
        I specialize in control and robot safety. 
        When I'm not in the lab, I'm usually exploring nature, playing drums, or eating.
      </p>
      <p class="text-sm font-light italic border-t border-white/10 pt-2">
        "I believe in 2 things: Christ is King and AI won't replace humans."
      </p>
    </div>

    <div class="relative w-full overflow-hidden rounded-lg group">
      <div class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-1">
        {photos.map((photo) => (
          <div class="min-w-full snap-center aspect-video bg-gray-800">
            <img 
              src={photo.src} 
              alt={photo.alt} 
              class="w-full h-full object-cover pointer-events-none"
            />
          </div>
        ))}
      </div>
      <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1">
        {photos.map((_) => (
          <div class="w-1.5 h-1.5 rounded-full bg-white/50"></div>
        ))}
      </div>
    </div>
  </div>
</Card>

<style>
  /* Hides scrollbar but allows sliding */
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>