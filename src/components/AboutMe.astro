---
import Card from "./Card/index.astro";
---

<Card colSpan="md:col-span-1" rowSpan="md:row-span-6" title="About me">
  <div class="flex flex-col gap-4 h-full">
    <div class="flex flex-col gap-2">
      <div class="text-sm font-light">
        <p>
          I was born in Indonesia, home to the world's best food and most stunning underwater scenery. 
        </p>
      </div>
      <p class="text-sm font-light">
        I love tinkering and fixing things. When I'm not in the lab, you can usually find me exploring nature, playing the drums, or eating.
      </p>
      <p class="text-sm font-light">
        Taking my work seriously, but never taking myself too seriously.
      </p>
      <p class="text-sm font-light italic border-t border-white/10 pt-2">
        My proudest photos
      </p>
    </div>
    
    <div class="relative w-full group">
      <div 
        id="photo-slider"
        class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-0 rounded-lg"
      >
        <!-- Slide 1 -->
        <div class="min-w-full snap-center bg-gray-900 shrink-0 flex flex-col">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-t-lg">
            <img src="/images/Best Photos/1.webp" alt="Clownfish" class="w-full h-full object-cover pointer-events-none" />
          </div>
          <div class="py-3 px-4 text-center text-white text-sm font-medium bg-gray-900 rounded-b-lg">
            Clownfish chilling in its anemone
          </div>
        </div>

        <!-- Slide 2 -->
        <div class="min-w-full snap-center bg-gray-900 shrink-0 flex flex-col">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-t-lg">
            <img src="/images/Best Photos/2.webp" alt="Green turtle" class="w-full h-full object-cover pointer-events-none" />
          </div>
          <div class="py-3 px-4 text-center text-white text-sm font-medium bg-gray-900 rounded-b-lg">
            A not-so-'Green' sea turtle
          </div>
        </div>

        <!-- Slide 3 -->
        <div class="min-w-full snap-center bg-gray-900 shrink-0 flex flex-col">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-t-lg">
            <img src="/images/Best Photos/3.webp" alt="Lionfish" class="w-full h-full object-cover pointer-events-none" />
          </div>
          <div class="py-3 px-4 text-center text-white text-sm font-medium bg-gray-900 rounded-b-lg">
            A camouflaging lionfish
          </div>
        </div>

        <!-- Slide 4 -->
        <div class="min-w-full snap-center bg-gray-900 shrink-0 flex flex-col">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-t-lg">
            <img src="/images/Best Photos/4.webp" alt="Diving buddy" class="w-full h-full object-cover pointer-events-none" />
          </div>
          <div class="py-3 px-4 text-center text-white text-sm font-medium bg-gray-900 rounded-b-lg">
            My diving buddy
          </div>
        </div>

        <!-- Slide 5 -->
        <div class="min-w-full snap-center bg-gray-900 shrink-0 flex flex-col">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-t-lg">
            <img src="/images/Best Photos/5.webp" alt="Coral" class="w-full h-full object-cover pointer-events-none" />
          </div>
          <div class="py-3 px-4 text-center text-white text-sm font-medium bg-gray-900 rounded-b-lg">
            The vibrant coral triangle
          </div>
        </div>
      </div>
    </div>

      <button 
        id="prev-btn"
        class="absolute left-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/80 text-white p-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <button 
        id="next-btn"
        class="absolute right-2 top-1/2 -translate-y-1/2 bg-black/50 hover:bg-black/80 text-white p-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</Card>

<script>
  const slider = document.getElementById('photo-slider');
  const nextBtn = document.getElementById('next-btn');
  const prevBtn = document.getElementById('prev-btn');

  nextBtn?.addEventListener('click', () => {
    slider?.scrollBy({ left: slider.clientWidth, behavior: 'smooth' });
  });

  prevBtn?.addEventListener('click', () => {
    slider?.scrollBy({ left: -slider.clientWidth, behavior: 'smooth' });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>