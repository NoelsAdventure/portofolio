---
import Card from "./Card/index.astro";
---

<script>
  function updateClocks() {
    const visitorDisplay = document.getElementById("visitorTime");
    const myDisplay = document.getElementById("myTime");
    const now = new Date();

    if (visitorDisplay) {
      // Shows the time exactly as it is on the visitor's computer
      visitorDisplay.textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true
      });
    }

    if (myDisplay) {
      // Forces the display to show your local time in Texas (CST/CDT)
      myDisplay.textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
        timeZone: 'America/Chicago'
      });
    }
  }

  // Update every second
  setInterval(updateClocks, 1000);
  updateClocks(); // Initial call
</script>

<Card colSpan="md:col-span-1" rowSpan="md:row-span-2" title="Time zone">
  <div class="flex flex-col justify-center h-full gap-2 py-2">
    <div>
      <p class="text-[10px] text-gray-500 uppercase tracking-widest">my time</p>
      <div class="flex items-baseline gap-1">
        <span id="myTime" class="text-xl xl:text-2xl font-bold whitespace-nowrap">--:-- --</span>
        <span class="text-[10px] text-gray-500">CST</span>
      </div>
    </div>

    <div class="border-t border-white/5 pt-2">
      <p class="text-[10px] text-gray-500 uppercase tracking-widest">your time</p>
      <div class="flex items-baseline gap-1">
        <span id="visitorTime" class="text-xl xl:text-2xl font-bold whitespace-nowrap">--:-- --</span>
        <span class="text-[10px] text-gray-500" id="visitorZone">
          {Intl.DateTimeFormat().resolvedOptions().timeZone.split('/')[1] || 'Local'}
        </span>
      </div>
    </div>
  </div>
</Card>