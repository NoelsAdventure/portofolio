---
import Card from "./Card/index.astro";
---

<script>
  function updateClocks() {
    const visitorDisplay = document.getElementById("visitorTime");
    const myDisplay = document.getElementById("myTime");
    const now = new Date();

    if (visitorDisplay) {
      // Shows the time exactly as it is on the visitor's computer
      visitorDisplay.textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true
      });
    }

    if (myDisplay) {
      // Forces the display to show your local time in Texas (CST/CDT)
      myDisplay.textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
        timeZone: 'America/Chicago'
      });
    }
  }

  // Update every second
  setInterval(updateClocks, 1000);
  updateClocks(); // Initial call
</script>

<Card colSpan="lg:col-span-1" rowSpan="md:row-span-3" title="Time zone">
  <div class="flex flex-col justify-center h-full gap-4">
    <div>
      <p class="text-xs text-gray-500 font-sans">my time</p>
      <div class="flex items-baseline gap-2">
        <span id="myTime" class="text-2xl xl:text-5xl font-serif">--:-- --</span>
        <span class="text-xs text-gray-500">CST</span>
      </div>
    </div>

    <div>
      <p class="text-xs text-gray-500 font-sans">your time</p>
      <div class="flex items-baseline gap-2">
        <span id="visitorTime" class="text-2xl xl:text-5xl font-serif">--:-- --</span>
        <span class="text-xs text-gray-500 font-sans" id="visitorZone">
          {Intl.DateTimeFormat().resolvedOptions().timeZoneName || 'Local'}
        </span>
      </div>
    </div>
  </div>
</Card>