---
import Card from "./Card/index.astro";
---

<script>
  function updateClocks() {
    const visitorDisplay = document.getElementById("visitorTime");
    const myDisplay = document.getElementById("myTime");
    const now = new Date();

    if (visitorDisplay) {
      visitorDisplay.textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true
      });
    }

    if (myDisplay) {
      // Correctly set to your location in Sugar Land, TX
      myDisplay.textContent = now.toLocaleTimeString('en-US', {
        hour: 'numeric',
        minute: '2-digit',
        hour12: true,
        timeZone: 'America/Chicago'
      });
    }
  }

  setInterval(updateClocks, 1000);
  updateClocks(); 
</script>

<Card colSpan="lg:col-span-2" rowSpan="md:row-span-2" title="Time zone">
  <div class="flex flex-col justify-center h-full gap-4">
    <div>
      <p class="text-xs text-gray-500">my time</p>
      <div class="flex items-baseline gap-2">
        <span id="myTime" class="text-2xl xl:text-5xl font-bold">--:-- --</span>
        <span class="text-xs text-gray-500">CST</span>
      </div>
    </div>

    <div>
      <p class="text-xs text-gray-500">your time</p>
      <div class="flex items-baseline gap-2">
        <span id="visitorTime" class="text-2xl xl:text-5xl font-bold">--:-- --</span>
        <span class="text-xs text-gray-500" id="visitorZone">
          {Intl.DateTimeFormat().resolvedOptions().timeZone || 'Local'}
        </span>
      </div>
    </div>
  </div>
</Card>