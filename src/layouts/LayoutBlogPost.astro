---
import { formatDate } from "../lib/helpers";
import BasicLayout from "./BasicLayout.astro";

type Props = {
  title: string;
  description: string;
  pubDate: Date;
  minutesRead: string;
  url: string;
  category: string; // Added category
  password?: string; // Added optional password
};

const { title, description, pubDate, minutesRead, url, category, password } = Astro.props;
---

<BasicLayout description={description} page="blog" slug={url} title={title}>
  <main class="mx-auto max-w-3xl w-full min-h-screen p-8 text-neutral-100">
    <a
      class="text-white bg-neutral-900 hover:bg-neutral-800 px-4 py-2 border-1 border-solid border-neutral-600 rounded-lg mb-8 inline-block"
      href="/blog">Back</a
    >
    
    <div class="my-10">
      <!-- Requirement 1: Replaced 'Post' context with Category -->
      <span class="text-xs font-bold uppercase tracking-widest text-red-500">{category}</span>
      <h1 class="text-5xl font-semibold mt-2">{title}</h1>
      
      <div class="flex justify-between pt-4 text-gray-500 text-sm">
        <p>{formatDate(pubDate)}</p>
        <p>{minutesRead}</p>
      </div>
    </div>

    <!-- Requirement 2: Password Logic -->
    {password ? (
      <div id="password-gate" class="bg-neutral-900 p-8 border border-neutral-800 rounded-xl text-center">
        <h2 class="text-xl mb-4">This post is protected</h2>
        <input 
          type="password" 
          id="pw-input" 
          placeholder="Enter password" 
          class="bg-neutral-800 border border-neutral-600 rounded px-3 py-2 text-white focus:outline-none focus:border-red-500"
        />
        <button 
          id="pw-submit" 
          class="ml-2 bg-red-600 hover:bg-red-500 px-4 py-2 rounded font-medium transition-colors"
        >
          Unlock
        </button>
        <p id="pw-error" class="text-red-500 mt-2 hidden">Incorrect password. Try again.</p>
      </div>

      <article id="protected-content" class="prose prose-p:text-red-500 prose-slate prose-invert hidden">
        <slot />
      </article>
    ) : (
      <article class="prose prose-p:text-red-500 prose-slate prose-invert">
        <slot />
      </article>
    )}
  </main>
</BasicLayout>

<script is:inline define:vars={{ password }}>
  // Simple client-side gate
  if (password) {
    const gate = document.getElementById('password-gate');
    const content = document.getElementById('protected-content');
    const input = document.getElementById('pw-input');
    const submit = document.getElementById('pw-submit');
    const error = document.getElementById('pw-error');

    submit.addEventListener('click', () => {
      if (input.value === password) {
        gate.classList.add('hidden');
        content.classList.remove('hidden');
      } else {
        error.classList.remove('hidden');
        input.value = '';
      }
    });

    // Allow "Enter" key to submit
    input.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') submit.click();
    });
  }
</script>

<style is:global>
  /* ... your existing styles ... */
</style>