---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ProjectRow from "../../components/projects/ProjectsRow.astro";

// Fetch from a "project" collection (you'll need to define this in content/config.ts)
const projects = (await getCollection("project"))?.sort(
  (a, b) => (b.data.pubDate || new Date()).getTime() - (a.data.pubDate || new Date()).getTime()
);
---

<Layout description="Research portfolio and robotics projects" title="Noel - Projects">
  <main class="w-screen min-h-screen flex flex-col justify-start items-start max-w-3xl mx-auto p-8">
    <a 
      class="text-white bg-neutral-900 hover:bg-neutral-800 px-4 py-2 mb-8 border border-solid border-neutral-600 rounded-lg" 
      href="/"
    >
      Back
    </a>

    <h1 class="text-4xl font-bold mb-10 text-neutral-100">Research & Projects</h1>

    <section class="w-full">
      {
        projects?.map((project) => (
          <ProjectRow
            id={project.id}
            title={project.data.title}
            authors={project.data.authors}
            venue={project.data.venue}
            description={project.data.description}
            image={project.data.image}
          />
        ))
      }
    </section>
  </main>
</Layout>